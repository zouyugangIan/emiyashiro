  {
    "label": "Debug client",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": { "command": "cargo", "args": ["build", "--bin", "client"] },
    "program": "$ZED_WORKTREE_ROOT/target/debug/client.exe",
