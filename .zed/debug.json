    "sourceLanguages": ["rust"],
    "env": {
      "RUST_BACKTRACE": "1",
      "CARGO_MANIFEST_DIR": "D:/Projects/emiyashiro",
    },
  },
  {
    "label": "Debug server",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": { "command": "cargo", "args": ["build", "--bin", "server"] },
    "program": "$ZED_WORKTREE_ROOT/target/debug/server.exe",
    "cwd": "$ZED_WORKTREE_ROOT",
    "sourceLanguages": ["rust"],
    "env": {
      "RUST_BACKTRACE": "1",
      "CARGO_MANIFEST_DIR": "D:/Projects/emiyashiro",
    },
  },
