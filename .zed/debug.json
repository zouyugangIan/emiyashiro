[
  {
    "label": "Debug client (Linux/macOS)",
    "adapter": "CodeLLDB",
    "request": "launch",
    "build": {
      "command": "cargo",
      "args": ["build", "--bin", "client", "--package", "emiyashiro"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/client",
    "cwd": "$ZED_WORKTREE_ROOT",
    "sourceLanguages": ["rust"],
    "env": {
      "RUST_BACKTRACE": "1",
    },
  },
