{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug client",
      "program": "${cargo:program}",
      "cargo": {
        "args": ["build", "--bin=client", "--package=s--emiyashiro"],
        "filter": {
          "name": "client",
          "kind": "bin",
        },
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
      },
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug server",
      "program": "${cargo:program}",
      "cargo": {
        "args": [
          "build",
          "--bin=server",
          "--no-default-features",
          "--features=server",
          "--package=s--emiyashiro",
        ],
        "filter": {
          "name": "server",
          "kind": "bin",
        },
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
      },
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug architecture_metrics",
      "program": "${cargo:program}",
      "cargo": {
        "args": [
          "build",
          "--bin=architecture_metrics",
          "--package=s--emiyashiro",
        ],
        "filter": {
          "name": "architecture_metrics",
          "kind": "bin",
        },
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
      },
    },
  ],
}
