{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Ubuntu Dev: client",
      "program": "${cargo:program}",
      "cargo": {
        "args": ["build", "--bin", "client", "--package", "emiyashiro"],
        "filter": {
          "name": "client",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "full",
        "RUST_LIB_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Ubuntu Dev: server",
      "program": "${cargo:program}",
      "cargo": {
        "args": [
          "build",
          "--bin",
          "server",
          "--no-default-features",
          "--features",
          "server",
          "--package",
          "emiyashiro"
        ],
        "filter": {
          "name": "server",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "full",
        "RUST_LIB_BACKTRACE": "1"
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Ubuntu Dev: architecture_metrics",
      "program": "${cargo:program}",
      "cargo": {
        "args": [
          "build",
          "--bin",
          "architecture_metrics",
          "--package",
          "emiyashiro"
        ],
        "filter": {
          "name": "architecture_metrics",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "RUST_BACKTRACE": "full",
        "RUST_LIB_BACKTRACE": "1"
      }
    }
  ]
}
